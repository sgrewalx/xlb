{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xlb.codemachine.in/schemas/experiment-queue.schema.json",
  "title": "XLB Experiment Queue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "updatedAt",
    "items"
  ],
  "properties": {
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "ownerAgent",
          "risk",
          "status",
          "hypothesis",
          "targetPaths",
          "successMetric"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "ownerAgent": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "running",
              "awaiting_review",
              "accepted",
              "rejected",
              "measuring",
              "completed"
            ]
          },
          "hypothesis": {
            "type": "string",
            "minLength": 1
          },
          "targetPaths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "successMetric": {
            "type": "string",
            "minLength": 1
          },
          "rollbackPlan": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
