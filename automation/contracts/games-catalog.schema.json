{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xlb.codemachine.in/schemas/games-catalog.schema.json",
  "title": "XLB Games Catalog Feed",
  "type": "object",
  "additionalProperties": false,
  "required": ["updatedAt", "thesis", "items"],
  "properties": {
    "updatedAt": { "type": "string", "format": "date-time" },
    "thesis": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "mode",
          "title",
          "description",
          "prompt",
          "relatedPath",
          "relatedLabel",
          "metricLabel",
          "metricValue",
          "featured"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "mode": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string", "minLength": 1 },
          "relatedPath": { "type": "string", "minLength": 1 },
          "relatedLabel": { "type": "string", "minLength": 1 },
          "metricLabel": { "type": "string", "minLength": 1 },
          "metricValue": { "type": "string", "minLength": 1 },
          "featured": { "type": "boolean" }
        }
      }
    }
  }
}
