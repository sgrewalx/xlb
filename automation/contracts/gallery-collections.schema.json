{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xlb.codemachine.in/schemas/gallery-collections.schema.json",
  "title": "XLB Gallery Collections Feed",
  "type": "object",
  "additionalProperties": false,
  "required": ["updatedAt", "thesis", "items"],
  "properties": {
    "updatedAt": { "type": "string", "format": "date-time" },
    "thesis": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "description", "category", "relatedPath", "relatedLabel", "entries"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "enum": ["quake", "aurora", "launch", "topic"] },
          "relatedPath": { "type": "string", "minLength": 1 },
          "relatedLabel": { "type": "string", "minLength": 1 },
          "entries": { "type": "array", "minItems": 1 }
        }
      }
    }
  }
}
