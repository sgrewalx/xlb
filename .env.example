# Generic snapshot import
# Point this at a normalized analytics JSON file if you want to import local data.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
XLB_ANALYTICS_SOURCE=./automation/capture-analytics/fixtures/cloudflare-sample.json
XLB_GA4_SOURCE=./automation/capture-analytics/fixtures/ga4-sample.json
XLB_SEARCH_CONSOLE_SOURCE=./automation/capture-analytics/fixtures/search-console-sample.json
GA4_PROPERTY_ID=
SEARCH_CONSOLE_SITE_URL=https://xlb.codemachine.in/
# Real local exports can live here instead:
# XLB_GA4_SOURCE=./data/analytics/ga4-export.csv
# XLB_SEARCH_CONSOLE_SOURCE=./data/analytics/search-console-export.csv
XLB_SNAPSHOT_DATE=2026-03-27
XLB_GA4_LOOKBACK_DAYS=1
XLB_SEARCH_CONSOLE_LAG_DAYS=2
XLB_SEARCH_CONSOLE_LOOKBACK_DAYS=7
XLB_FORCE_COLD_START=0
XLB_MIN_ANALYTICS_COVERAGE=0.6
XLB_MIN_HEALTHY_STREAK=3
XLB_MIN_ANALYTICS_STREAK=3
XLB_MIN_AUTONOMY_STREAK=3
XLB_AUTONOMY_HISTORY_LIMIT=14
XLB_MIN_SOURCE_STABILITY_STREAK=3
XLB_SOURCE_HISTORY_LIMIT=14

# Optional Cloudflare zone-based GraphQL fetch
# Only use these if the site exists as a Cloudflare zone.
# For a snippet-only, non-proxied setup on AWS DNS, leave these unset.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_TAG=
# XLB_CF_START=2026-03-26T00:00:00Z
# XLB_CF_END=2026-03-27T00:00:00Z

# Optional Google API credentials for automated real analytics ingestion
# Either point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON file
# or provide the full JSON as GOOGLE_SERVICE_ACCOUNT_JSON.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
